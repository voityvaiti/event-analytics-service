#!/bin/bash

# Run tests and generate the JaCoCo coverage report, then print a console
# summary — JaCoCo itself only writes files, so we parse the XML report and
# echo the totals. Full HTML: build/reports/jacoco/test/html/index.html.

cd "$(dirname "$0")/../.." || exit 1

./gradlew jacocoTestReport "$@" || exit $?

XML="build/reports/jacoco/test/jacocoTestReport.xml"
[ -f "$XML" ] || { echo "No coverage XML at $XML"; exit 0; }

# Report-level totals are the LAST <counter> of each type in the file
# (package/class counters come first, the overall total comes last).
echo
echo "Coverage summary:"
grep -o '<counter type="[A-Z]*" missed="[0-9]*" covered="[0-9]*"/>' "$XML" \
  | sed -E 's/.*type="([A-Z]*)" missed="([0-9]*)" covered="([0-9]*)".*/\1 \2 \3/' \
  | awk '
      { missed[$1] = $2; covered[$1] = $3 }   # last assignment wins = total
      END {
        order = "INSTRUCTION BRANCH LINE METHOD CLASS COMPLEXITY"
        n = split(order, types, " ")
        for (i = 1; i <= n; i++) {
          t = types[i]
          if (!(t in covered)) continue
          total = covered[t] + missed[t]
          pct = total > 0 ? 100 * covered[t] / total : 0
          printf "  %-12s %6.1f%%  (%d/%d)\n", t, pct, covered[t], total
        }
      }'
echo
echo "  HTML: build/reports/jacoco/test/html/index.html"
