#!/bin/bash

# Measure ingest write throughput and append one row to load/journal.jsonl.
# This task is the ONLY writer of the journal — rows are never hand-edited.
#
# Each row self-stamps the measurement rig (CPU, cores) alongside the
# config that makes a throughput number meaningful (pool, VUs, starting rows),
# because absolute numbers are only comparable within a fixed rig — a row from a
# different machine is a different series, not a regression.
#
# Contract: the app must already be running on the host. Backing services are
# brought up here from compose.yaml. Tunables: BASE_URL, VUS, DURATION. The pool
# size is not passed in — it is read live from the running app (see below), so
# the journalled value is always the one the run actually used.
#
# k6 runs in a container (image pinned to K6_IMAGE), so nothing needs installing
# on the host beyond Docker — which is already required for the backing services.

set -euo pipefail
cd "$(dirname "$0")/../.." || exit 1

export BASE_URL=${BASE_URL:-http://localhost:8080}
SUMMARY=load/last-summary.json
JOURNAL=load/journal.jsonl
K6_IMAGE=${K6_IMAGE:-grafana/k6:0.50.0}

# Write-path semantics at the moment k6 sees the response — the one stamp not
# read from the app, because nothing exposes it yet. Today the controller
# returns 202 only after the synchronous DB write, so throughput is genuine
# write throughput: "sync". Once a buffer fronts the write (Kafka, or in-process
# coalescing) the 202 returns before the row lands and the same number measures
# intake, not persistence — set INGEST_PATH accordingly so the two never merge
# into one series. Derive it from the app instead of here once it can be.
INGEST_PATH=${INGEST_PATH:-sync}

# Run the pinned k6 image against the host-resident app and repo.
#   --network host    so localhost:8080 (and the summary's base_url) match a
#                     host run exactly. Linux-only; Docker Desktop would instead
#                     need BASE_URL=http://host.docker.internal:8080.
#   --user $(id -u)…  so the summary file k6 writes into the mounted load/ dir
#                     is owned by us, not the image's baked-in uid.
# Env is forwarded explicitly as KEY=VALUE; callers append overrides via "$@",
# and a later -e wins, so warm-up can override RAMP/DURATION/SUMMARY_OUT.
k6_run() {
  docker run --rm --network host \
    --user "$(id -u):$(id -g)" \
    --volume "$PWD":/work --workdir /work \
    --env BASE_URL --env VUS --env DURATION --env RAMP --env SUMMARY_OUT \
    --env RUN_ID --env TOKEN \
    "$@" \
    "$K6_IMAGE" run load/ingest-events.js
}

scripts/actions/dependencies

if ! curl -sf "$BASE_URL/actuator/health" | grep -q '"status":"UP"'; then
  echo "App is not healthy at $BASE_URL — start it (e.g. ./gradlew bootRun) and retry." >&2
  exit 1
fi

# Pull/verify the k6 image up front so a missing image or broken Docker fails
# here with a clear cause, not as a swallowed warm-up error surfacing later.
if ! docker run --rm "$K6_IMAGE" version >/dev/null 2>&1; then
  echo "Could not run the k6 image '$K6_IMAGE' — is Docker available and the image pullable?" >&2
  exit 1
fi

reset_db() {
  docker compose exec -T postgres psql -U event_analytics -d event_analytics -c 'TRUNCATE events;'
}

# Warm up (JIT + connection pool) and throw the numbers away, so the measured
# run reflects steady state rather than cold start.
reset_db
k6_run --env RAMP=3s --env DURATION=10s --env SUMMARY_OUT=/dev/null || true

# Measured run, from a known-empty table. k6 writes $SUMMARY.
reset_db
k6_run

# Read the pool the run ACTUALLY used straight from the app, rather than trust a
# value passed in — a journalled config the run did not use would be a quiet lie.
pool=$(curl -sf "$BASE_URL/actuator/metrics/hikaricp.connections.max" \
  | python3 -c 'import json, sys; print(int(json.load(sys.stdin)["measurements"][0]["value"]))') || {
  echo "Could not read pool size from the app's actuator metrics — is the 'metrics' endpoint exposed?" >&2
  exit 1
}

# Stamp the schema the run actually hit, read from the migrated DB rather than
# assumed: secondary indexes (a GIN on properties especially) make every INSERT
# costlier, so throughput drops when they land — this column says "that drop is
# a new migration, not a regression" without a commit-by-commit hunt.
schema_version=$(docker compose exec -T postgres psql -U event_analytics -d event_analytics -tAc \
  "SELECT version FROM flyway_schema_history WHERE success ORDER BY installed_rank DESC LIMIT 1" \
  | tr -d '[:space:]') || {
  echo "Could not read the schema version from flyway_schema_history." >&2
  exit 1
}

python3 - "$SUMMARY" "$JOURNAL" "$(date -u +%Y-%m-%d)" "$(git rev-parse --short HEAD)" \
  "$(grep -m1 'model name' /proc/cpuinfo | sed 's/.*: //')" "$(nproc)" "$pool" \
  "$INGEST_PATH" "$schema_version" <<'PY'
import json, sys

summary_path, journal_path, date, commit, cpu, cores, pool, ingest_path, schema_version = (
    sys.argv[1:10]
)
with open(summary_path) as f:
    s = json.load(f)

row = {
    "date": date,
    "commit": commit,
    "scenario": s["scenario"],
    "ingest_path": ingest_path,
    "schema_version": schema_version,
    "cpu": cpu,
    "cores": int(cores),
    "pool": int(pool),
    "vus": s["vus"],
    "start_rows": 0,
    "requests": round(s["requests"]),
    "throughput_rps": round(s["throughput_rps"], 1),
    "p95_ms": round(s["latency_ms"]["p95"], 2),
    "p99_ms": round(s["latency_ms"]["p99"], 2),
    "failed_rate": s["failed_rate"],
}

with open(journal_path, "a") as f:
    f.write(json.dumps(row) + "\n")

print("\nAppended to " + journal_path + ":")
print(json.dumps(row))
PY

echo
echo "Eyeball the line above, then commit journal.jsonl yourself."